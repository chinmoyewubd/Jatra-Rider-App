<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    android:backgroundTint="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- Main Bus Card Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Left Icon with Background -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/circle_bg"
                android:backgroundTint="#E3F2FD"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/bus_24"
                    android:contentDescription="Bus Icon"
                    app:tint="#15314F" />
            </LinearLayout>

            <!-- Middle Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <!-- Driver Name + Status Badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/busName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Driver: Alif"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:textColor="#1A1A1A"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <!-- Status Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_border"
                        android:backgroundTint="#E8F5E9"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/statusDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#4CAF50" />

                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Active"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="#2E7D32" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Bus Number -->
                <TextView
                    android:id="@+id/money"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dhaka Metro-GHA 31-9957"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#15314F"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Distance + Location in One Line -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/location_mark_24"
                        app:tint="#FF6B6B" />

                    <TextView
                        android:id="@+id/distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="200 m"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="4dp"
                        android:textColor="#FF6B6B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" away at "
                        android:textSize="14sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/placeName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Brac University"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:maxLines="1"
                         />
                </LinearLayout>

                <!-- Phone Number -->
                <TextView
                    android:id="@+id/phoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phone: 017XXXXXXXX"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#888888"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Right Arrow Button -->
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg"

                android:gravity="center"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/arrow"
                    app:tint="@android:color/white" />
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="#E0E0E0" />

        <!-- EAT / ETT Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:background="#FAFAFA">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EAT:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/eat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginStart="6dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETT:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/ettTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>